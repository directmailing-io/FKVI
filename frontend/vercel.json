{
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/brochure-send-contracts",
      "schedule": "0 8 * * *"
    }
  ],
  "experimentalServices": {
    "web": {
      "framework": "vite",
      "buildCommand": "vite build",
      "outputDirectory": "dist",
      "installCommand": "npm install"
    }
  }
}
